BOT_TOKEN=your_bot_token_here
WEBAPP_URL=https://your-domain.example.com
ENABLE_LOGGING=true
TZ=Europe/Moscow

# YooKassa (get from yookassa.ru → My shops → API keys)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET=your_secret_key
SUBSCRIPTION_PRICE=199.00

# Trial period in seconds: 604800 = 7 days
TRIAL_SECONDS=604800

# Admin user IDs (comma-separated)
ADMIN_USER_IDS=

# PostgreSQL
PG_HOST=postgres
PG_PORT=5432
PG_DB=habits
PG_USER=habits
PG_PASSWORD=your_password
